<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg123743.ui.javafx.controller.BattleController"
            styleClass="battle-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <Label fx:id="turnLabel" text="Turn 1 - Player" styleClass="turn-label"/>
            <Button text="Save Game" onAction="#onSave" styleClass="action-button"/>
            <Button text="Main Menu" onAction="#onMenuClicked" styleClass="action-button"/>
            <Button text="End Turn" onAction="#onEndTurn" styleClass="action-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="false" fitToHeight="false" styleClass="map-scroll">
            <GridPane fx:id="mapGrid" alignment="CENTER" hgap="2" vgap="2" styleClass="map-grid">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </GridPane>
        </ScrollPane>
    </center>

    <right>
        <VBox spacing="10" prefWidth="200" styleClass="sidebar">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Unit Info" styleClass="panel-header"/>
            <VBox fx:id="unitInfoPanel" spacing="5"/>
        </VBox>
    </right>

    <bottom>
        <VBox spacing="6" styleClass="combat-log-bar">
            <padding>
                <Insets top="8" right="14" bottom="10" left="14"/>
            </padding>
            <Label text="Combat Log" styleClass="panel-header"/>
            <TextArea fx:id="combatLog" editable="false" prefHeight="110" styleClass="combat-log"/>
        </VBox>
    </bottom>

</BorderPane>