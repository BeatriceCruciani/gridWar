<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg123743.ui.javafx.controller.MainMenuController"
      styleClass="main-menu"
      alignment="CENTER"
      spacing="20">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Text fx:id="titleText" text="GRIDWAR" styleClass="title"/>
    <Text text="A Tactical RPG" styleClass="subtitle"/>

    <Button fx:id="newGameBtn" text="New Game"
            styleClass="menu-button" prefWidth="200"
            onAction="#onNewGame"/>

    <Button fx:id="loadGameBtn" text="Load Game"
            styleClass="menu-button" prefWidth="200"
            onAction="#onLoadGame"/>

    <Button fx:id="quitBtn" text="Quit"
            styleClass="menu-button" prefWidth="200"
            onAction="#onQuit"/>

</VBox>